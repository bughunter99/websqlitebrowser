{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "browser/static/browser/**/*.js",
    "browser/static/browser/**/*.d.ts",
    "tests/**/*.js",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
