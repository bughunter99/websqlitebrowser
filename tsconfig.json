{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "browser/static/browser/globals.d.ts",
    "browser/static/browser/app.api.js",
    "browser/static/browser/app.explorer.js",
    "browser/static/browser/app.db.js",
    "browser/static/browser/app.tabs.js",
    "browser/static/browser/app.events.js",
    "browser/static/browser/app.query.js",
    "browser/static/browser/app.state.js",
    "tests/**/*.js",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
